{
	"$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
	"vcs": {
		"enabled": true,
		"clientKind": "git",
		"useIgnoreFile": true
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"nursery": {
				"useExplicitType": "off"
			},
			"correctness": {
				"useValidForDirection": "error",
				"noConstAssign": "error",
				"noUnusedVariables": "error"
			},
			"style": {
				"useSingleVarDeclarator": "error",
				"noUselessElse": "warn"
			},
			"suspicious": {
				"noVar": "error",
				"noEmptyBlockStatements": "error",
				"noAssignInExpressions": "error",
				"noDoubleEquals": "error",
				"noUnsafeNegation": "error",
				"noRedeclare": "error",
				"noExplicitAny": "error"
			}
		}
	},
	"javascript": {
		"formatter": {
			"enabled": true,
			"lineWidth": 100,
			"quoteStyle": "double",
			"trailingCommas": "all",
			"semicolons": "always",
			"attributePosition": "multiline",
			"bracketSpacing": true
		}
	},
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["src/**/*.ts", "src/**/*.tsx", "**", "!!**/dist", "!!src/**/*.d.ts"]
	},
	"css": {
		"parser": {
			"tailwindDirectives": true
		}
	}
}
